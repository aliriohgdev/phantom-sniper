# Private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# RPC / WebSocket / IPC (own BSC node)
BSC_RPC=http://127.0.0.1:8545
BSC_WS=ws://127.0.0.1:8546
# Optional IPC path for lower-latency subscriptions.
# If set and the socket exists, IPC is used instead of WS (~0.1ms vs ~1-5ms).
# Typical geth: $HOME/.ethereum/geth.ipc
# BSC_IPC=/opt/bsc-data/geth.ipc

# ============== MEV Relays ==============
# Bundles dispatched to ALL relays in parallel (~65-70% BSC block coverage)
# 48Club Puissant — ~25% hashrate
RELAY_48CLUB=https://puissant-bsc.48.club
# BlockRazor Builder — ~37% hashrate (requires auth token)
RELAY_BLOCKRAZOR=https://frankfurt.builder.blockrazor.io
BLOCKRAZOR_AUTH_TOKEN=your_blockrazor_token_here
# NodeReal MEV — ~5% hashrate (API key embedded in URL)
RELAY_NODEREAL=https://bsc-mainnet.nodereal.io/mev/v1/your_api_key

# Buy amount per token (BNB)
BUY_AMOUNT_BNB=0.001

# ---- Contract ----
# four.meme TokenManager contract address
MEME_CONTRACT_ADDRESS=0x5c952063c7fc8610FFDB798152D69F0B9550762b

# ---- Gas limits ----
BUY_GAS_LIMIT=300000
APPROVE_GAS_LIMIT=100000
SELL_GAS_LIMIT=500000
# Default gas price in wei (1.5 gwei). Used for non-frontrun approve/sell.
DEFAULT_GAS_PRICE=1500000000
# Extra gas premium in wei (5 gwei) for frontrun priority
FRONTRUN_GAS_PREMIUM=5000000000
# Dust amount in wei subtracted from sell amounts to avoid rounding issues
DUST_AMOUNT_WEI=1800000000000

# ---- Bundle ----
# Bundle valid for next N blocks
MAX_BLOCK_DELTA=3
# Max timestamp delta for bundle validity (seconds)
MAX_TIMESTAMP_DELTA=100

# ---- Filters ----
# Blacklisted developer addresses (comma-separated). Tokens by these devs are always skipped.
# DEV_BLACKLIST=0x1234...abcd,0x5678...ef01
# Min dev initial buy to consider token (BNB). Below = spam, skip.
MIN_DEV_BUY_BNB=0.13
# Max token creations per dev within window before blocking
DEV_RATE_LIMIT_COUNT=3
DEV_RATE_LIMIT_WINDOW_SECS=3600

# ---- Sell strategy ----
# Dev sell < this % of their balance → ignore (gas not worth it)
DEV_SELL_IGNORE_PCT=5
# Dev sell > this % → dump entire position. Between ignore and dump → proportional sell.
DEV_SELL_DUMP_PCT=50
# Cumulative dev sells > this % of initial balance → dump everything (anti-drip protection)
DEV_SELL_CUMULATIVE_DUMP_PCT=30

# ---- Position management ----
# Seconds to wait after backrun before verifying our token balance (default: 1 ≈ 3 BSC blocks)
POSITION_VERIFY_DELAY_SECS=1
# Max seconds to hold a position if price stagnates (doesn't change). 0 = disabled.
# If price moves (up or down), the timer resets.
# Prevents holding "dead" tokens with zero liquidity/activity.
STAGNATION_TTL_SECS=120
# Take-profit target (% above cost). 50 = sell when value reaches 150% of cost (50% profit). 0 = disabled.
TAKE_PROFIT_PCT=50
# Trailing stop-loss (% below peak). 30 = sell if value drops 30% from highest value seen. 0 = disabled.
# The peak is updated every check if current value > previous peak.
STOP_LOSS_PCT=30
# How often to check profit targets and stop-loss (seconds)
PROFIT_CHECK_INTERVAL_SECS=1
